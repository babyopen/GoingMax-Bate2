3.4 降权过滤器

typescript
function filterDowngraded(candidates: number[], window12: Map<number,number>, window11: Map<number,number>): number[] {
  return candidates.filter(num => {
    const c12 = window12.get(num) || 0;
    if (c12 >= 3) {
      const c11 = window11.get(num) || 0;
      return c11 === 2; // 仅当11期=2解除降权
    }
    return true;
  });
}
